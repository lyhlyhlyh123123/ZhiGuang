/* 阿里 iconfont - 在线链接方式 (真机可用) */
/* 项目 ID: 5145551 */
@font-face {
  font-family: 'iconfont';
  src: url('https://at.alicdn.com/t/c/font_5145551_xleh746v46.woff2?t=1775920628419') format('woff2'),
       url('https://at.alicdn.com/t/c/font_5145551_xleh746v46.woff?t=1775920628419') format('woff'),
       url('https://at.alicdn.com/t/c/font_5145551_xleh746v46.ttf?t=1775920628419') format('truetype');
}

.iconfont {
  font-family: 'iconfont' !important;
  font-size: 1em;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -webkit-text-stroke-width: 0.2px;
  -moz-osx-font-smoothing: grayscale;
  vertical-align: -0.125em;
  display: inline-block;
}

/* 为兼容旧代码，保留 .icon 类 */
.icon {
  font-family: 'iconfont' !important;
  font-size: 1em;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -webkit-text-stroke-width: 0.2px;
  -moz-osx-font-smoothing: grayscale;
  vertical-align: -0.125em;
  display: inline-block;
}

