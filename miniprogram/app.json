      { "pagePath": "pages/batch/batch", "text": "批量" },
      { "pagePath": "pages/feedback/feedback", "text": "反馈" }
    ]
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["__APP__"]
    }
  }
