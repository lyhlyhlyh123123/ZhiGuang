{
  "pages": [
    "pages/index/index",
    "pages/calendar/calendar",
    "pages/batch/batch",
    "pages/feedback/feedback",
    "pages/plant-detail/plant-detail",
    "pages/add-plant/add-plant",
    "pages/edit-plant/edit-plant",
    "pages/add-journal/add-journal",
    "pages/profile-edit/profile-edit"
  ],
  "window": {
    "backgroundColor": "#F0FDF4",
