<view class="tab-bar">
  <!-- 首页 -->
  <view class="tab-item {{selected === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
    <text class="iconfont icon-penzai tab-icon"></text>
    <text class="tab-text">首页</text>
  </view>

  <!-- 日历 -->
  <view class="tab-item {{selected === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
    <text class="iconfont icon-riqi tab-icon"></text>
    <text class="tab-text">日历</text>
  </view>

  <!-- 中间加号（凸起，复用首页悬浮按钮风格） -->
  <view class="tab-add" bindtap="goAdd">
    <view class="add-btn">
      <text class="iconfont icon-plus add-icon"></text>
    </view>
  </view>

  <!-- 批量 -->
  <view class="tab-item {{selected === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
    <text class="iconfont icon-jilu tab-icon"></text>
    <text class="tab-text">批量</text>
  </view>

  <!-- 反馈 -->
  <view class="tab-item {{selected === 3 ? 'active' : ''}}" bindtap="switchTab" data-index="3">
    <text class="iconfont icon-edit tab-icon"></text>
    <text class="tab-text">反馈</text>
  </view>
</view>
