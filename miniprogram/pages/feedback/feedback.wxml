<view class="page">

  <!-- Hero 区域：品牌 + 开发者留言 -->
  <view class="hero">
    <view class="hero-deco">
      <view class="deco-circle c1"></view>
      <view class="deco-circle c2"></view>
    </view>
    <text class="hero-title">植光 · ZhiGuang</text>
    <text class="hero-sub">记录每一寸破土而出的生命</text>

    <view class="update-card">
      <text class="update-title">✨ 本次更新 (2026-04-10)</text>
      <view class="update-list">
        <view class="update-item"><text class="update-tag">1</text><text class="update-desc">植物头像支持拖拽缩放裁剪</text></view>
        <view class="update-item"><text class="update-tag">2</text><text class="update-desc">到家日期改为选填项</text></view>
        <view class="update-item"><text class="update-tag">3</text><text class="update-desc">批量操作支持 / 联合搜索标签</text></view>
        <view class="update-item"><text class="update-tag">4</text><text class="update-desc">支持无限添加植物</text></view>
      </view>
    </view>

    <view class="hero-footer">
      <text class="hero-footer-text">如果植光对你有帮助，欢迎推荐给爱植物的朋友</text>
      <button class="share-btn" open-type="share">分享给朋友</button>
    </view>
  </view>

  <!-- 反馈表单 -->
  <view class="form-section">
    <view class="card">
      <text class="label">反馈内容</text>
      <textarea class="textarea" placeholder="遇到了什么问题？有什么建议？" value="{{content}}" bindinput="onContentInput" maxlength="500"></textarea>
      <text class="word-count">{{content.length}}/500</text>
    </view>

    <view class="card">
      <text class="label">联系方式（可选）</text>
      <input class="input" placeholder="微信号或邮箱，方便回复你" value="{{contact}}" bindinput="onContactInput" />
    </view>

    <button class="submit-btn {{content.length > 0 ? 'active' : ''}}" bindtap="submit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交反馈'}}
    </button>
  </view>

</view>
