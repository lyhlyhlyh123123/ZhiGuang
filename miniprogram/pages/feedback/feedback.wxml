<view class="page">

  <!-- Hero 区域：品牌 + 开发者留言 -->
  <view class="hero">
    <view class="hero-deco">
      <view class="deco-circle c1"></view>
      <view class="deco-circle c2"></view>
    </view>
    <text class="hero-title">小植书</text>
    <text class="hero-sub">记录每一寸破土而出的生命</text>

    <view class="update-card">
      <text class="update-title">✨ 本次更新 (2026-04-18)</text>
      <view class="update-list">
        <view class="update-item"><text class="update-tag">1</text><text class="update-desc">新增养护计划以及是否需要养护计划</text></view>
        <view class="update-item"><text class="update-tag">2</text><text class="update-desc">植物死掉结束陪伴功能（在编辑植物里面）</text></view>
        <view class="update-item"><text class="update-tag">3</text><text class="update-desc">新增杀菌、排序功能，分组功能目前还没想好，因为是小程序一开始没想做太多功能，会显得很臃肿</text></view>
        <view class="update-item"><text class="update-tag">4</text><text class="update-desc">基本上的主要功能已经完善了,有bug可以反馈</text></view>
        <view class="update-item"><text class="update-tag">5</text><text class="update-desc">用户现在不是很多,可以帮忙分享一下,感谢</text></view>
      </view>
    </view>

    <view class="hero-footer">
      <text class="hero-footer-text">如果小植书对你有帮助，欢迎推荐给爱植物的朋友</text>
      <button class="share-btn" open-type="share">分享给朋友</button>
    </view>
  </view>

  <!-- 反馈表单 -->
  <view class="form-section">
    <view class="card">
      <text class="label">反馈内容</text>
      <textarea class="textarea" placeholder="遇到了什么问题？有什么建议？" value="{{content}}" bindinput="onContentInput" maxlength="500"></textarea>
      <text class="word-count">{{content.length}}/500</text>
    </view>

    <button class="submit-btn {{content.length > 0 ? 'active' : ''}}" bindtap="submit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交反馈'}}
    </button>
  </view>

</view>
