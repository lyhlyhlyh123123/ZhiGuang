page { background: #F0FDF4; font-family: -apple-system, sans-serif; }
.page { padding: 48rpx 32rpx 200rpx; }

.header { display: flex; flex-direction: column; align-items: center; margin-bottom: 48rpx; }
.header-emoji { font-size: 80rpx; margin-bottom: 16rpx; }
.header-title { font-size: 40rpx; font-weight: 800; color: #1F2937; margin-bottom: 8rpx; }
.header-sub { font-size: 26rpx; color: #9CA3AF; }

.card { background: #FFFFFF; border-radius: 28rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.label { font-size: 28rpx; font-weight: 600; color: #374151; display: block; margin-bottom: 16rpx; }
.textarea { width: 100%; min-height: 200rpx; font-size: 28rpx; color: #374151; line-height: 1.6; }
.word-count { display: block; text-align: right; font-size: 22rpx; color: #D1D5DB; margin-top: 8rpx; }
.input { width: 100%; height: 72rpx; font-size: 28rpx; color: #374151; }

.submit-btn { width: 100% !important; height: 100rpx; background: #E5E7EB; color: #9CA3AF; border-radius: 50rpx; font-size: 32rpx; font-weight: 700; margin-top: 16rpx; }
.submit-btn.active { background: linear-gradient(135deg, #22C55E, #16A34A); color: #FFFFFF; box-shadow: 0 12rpx 32rpx rgba(34,197,94,0.3); }
