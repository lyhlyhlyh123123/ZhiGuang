.container {
  min-height: 100vh;
  background-color: #F0FDF4;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
}

.profile-header {
  margin-bottom: 80rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  color: #166534;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #86A789;
}

.setup-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.avatar-wrapper {
  background: none;
  padding: 0;
  width: 220rpx !important;
  height: 220rpx !important;
  border-radius: 50%;
  margin-bottom: 24rpx;
  position: relative;
  border: 8rpx solid #FFFFFF;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.08);
}

.setup-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #E8F5E9;
}

.avatar-edit-tag {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: #22C55E;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 4rpx solid #FFFFFF;
}

.avatar-edit-tag .icon {
  color: white;
  font-size: 32rpx;
}

/* 个人资料页图标颜色 */
.icon-image { color: #8B5CF6; }

.hint-text {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 60rpx;
}

.nickname-section {
  width: 100%;
}

.input-group {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
  margin-bottom: 12rpx;
}

.label {
  font-size: 30rpx;
  color: #374151;
  font-weight: 600;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  color: #1F2937;
}

.action-footer {
  width: 100%;
}

.save-btn {
  width: 100% !important;
  height: 110rpx;
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  color: #FFFFFF;
  border-radius: 55rpx;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 20rpx 40rpx rgba(34, 197, 94, 0.25);
  margin-bottom: 32rpx;
}

.btn-disabled {
  background: #D1D5DB !important;
  box-shadow: none !important;
  color: #F3F4F6 !important;
}

.logout-btn {
  background: none;
  color: #EF4444;
  font-size: 28rpx;
  font-weight: normal;
  text-decoration: underline;
}
