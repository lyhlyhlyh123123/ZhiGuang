<view class="page-container">
  
  <view class="nav-header">
    <view class="back-btn" bindtap="goBack"><text class="icon icon-back"></text></view>
    <view class="placeholder-box"></view>
  </view>

  <scroll-view scroll-y class="scroll-content">
    
    <!-- 多图片上传区域 -->
    <view class="section-title">植物照片 ({{tempImagePaths.length}}/{{maxImageCount}})</view>
    <view class="image-upload-container">
      <scroll-view scroll-x class="image-scroll-view">
        <view class="image-list">
          <!-- 已选择的图片 -->
          <view class="image-item {{selectedIndex === index ? 'selected' : ''}}" wx:for="{{tempImagePaths}}" wx:key="index" bindtap="onImageTap" data-index="{{index}}">
            <image src="{{item}}" mode="aspectFill" class="image-preview" />
            <!-- 封面标记 -->
            <view wx:if="{{index === 0}}" class="cover-badge">封面</view>
            <!-- 删除按钮 -->
            <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">
              <text class="icon icon-delete"></text>
            </view>
          </view>
          
          <!-- 添加按钮 -->
          <view wx:if="{{tempImagePaths.length < maxImageCount}}" class="add-image-btn" bindtap="chooseImages">
            <text class="icon icon-plus"></text>
            <text class="add-text">添加照片</text>
            <text class="add-hint">还能添加{{maxImageCount - tempImagePaths.length}}张</text>
          </view>
        </view>
      </scroll-view>
      <view class="upload-tip">
        <text class="icon icon-info"></text>
        <text>点击两张图片可交换位置，第一张照片为封面</text>
      </view>
    </view>

    <view class="section-title">基础信息</view>
    <view class="info-group">
      <view class="input-wrapper">
        <text class="input-label">植物昵称</text>
        <input class="styled-input" placeholder="给你的伙伴起个名字吧..." value="{{nickname}}" bindinput="onNicknameInput" />
      </view>
      
      <view class="input-wrapper">
        <text class="input-label">植物品种</text>
        <input class="styled-input" placeholder="例如：龟背竹、多肉..." value="{{species}}" bindinput="onSpeciesInput" />
        <view class="category-tags">
          <scroll-view scroll-x class="tags-scroll">
            <view class="tag-list">
              <view class="tag-chip {{species === item ? 'active' : ''}}" wx:for="{{speciesCategories}}" wx:key="index" bindtap="selectSpecies" data-val="{{item}}">
                {{item}}
                <text class="tag-delete" catchtap="deleteSpeciesCategory" data-val="{{item}}">×</text>
              </view>
              <view class="tag-chip add-tag" bindtap="showAddSpeciesDialog">
                <text class="icon icon-plus" style="font-size: 20rpx;"></text> 添加
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
      
      <view class="input-wrapper">
        <text class="input-label">摆放位置</text>
        <input class="styled-input" placeholder="例如：阳台、客厅、书桌..." value="{{location}}" bindinput="onLocationInput" />
        <view class="category-tags">
          <scroll-view scroll-x class="tags-scroll">
            <view class="tag-list">
              <view class="tag-chip {{location === item ? 'active' : ''}}" wx:for="{{locationCategories}}" wx:key="index" bindtap="selectLocation" data-val="{{item}}">
                {{item}}
                <text class="tag-delete" catchtap="deleteLocationCategory" data-val="{{item}}">×</text>
              </view>
              <view class="tag-chip add-tag" bindtap="showAddLocationDialog">
                <text class="icon icon-plus" style="font-size: 20rpx;"></text> 添加
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
      
      <view class="input-wrapper">
        <text class="input-label">来源 <text style="color:#9CA3AF;font-weight:400;">（选填）</text></text>
        <input class="styled-input" placeholder="例如：花市、朋友赠送、网购..." value="{{source}}" bindinput="onSourceInput" />
      </view>
      
      <view class="input-wrapper">
        <text class="input-label">到家日期 <text style="color:#9CA3AF;font-weight:400;">（选填）</text></text>
        <picker mode="date" value="{{adoptDate}}" bindchange="onDateChange">
          <view class="picker-text {{adoptDate ? '' : 'placeholder-color'}}">
            {{adoptDate || '选填，记录它来到你身边的日期'}}
          </view>
        </picker>
      </view>

      <view class="input-wrapper">
        <text class="input-label">备注 <text style="color:#9CA3AF;font-weight:400;">（选填）</text></text>
        <input class="styled-input" placeholder="记录一些特殊的备注信息..." value="{{remark}}" bindinput="onRemarkInput" />
      </view>
    </view>

    <view class="section-title mt-8">养护设定</view>
    <view class="settings-card">
      
      <view class="setting-item no-border">
        <view class="setting-info">
          <view class="setting-icon-wrap bg-blue">
            <text class="icon icon-water" style="font-size: 40rpx; color: #3B82F6;"></text>
          </view>
          <view class="setting-text">
            <text class="setting-name">浇水周期</text>
            <text class="setting-desc">每隔 {{waterInterval}} 天浇一次水</text>
          </view>
        </view>
        <view class="stepper">
          <view class="step-btn" bindtap="minusInterval">-</view>
          <text class="step-val">{{waterInterval}}</text>
          <view class="step-btn text-green" bindtap="addInterval">
            <text class="icon icon-plus" style="font-size: 24rpx;"></text>
          </view>
        </view>
      </view>
      
    </view>

  </scroll-view>

  <view class="bottom-bar">
    <button class="submit-btn" bindtap="submitPlant">加入我的花园</button>
  </view>

</view>