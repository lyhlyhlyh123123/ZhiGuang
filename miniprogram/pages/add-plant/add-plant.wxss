/* miniprogram/pages/add-plant/add-plant.wxss */
page {
  background-color: #f8faf8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 1. 顶部导航 */
.nav-header {
  padding: 96rpx 48rpx 32rpx; /* 适配手机状态栏 */
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f8faf8;
  z-index: 100;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  font-size: 40rpx;
  color: #1F2937;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
}

.placeholder-box { width: 64rpx; }

/* 内容滚动区 */
.scroll-content {
  flex: 1;
  padding: 16rpx 48rpx 240rpx; /* 底部留出空间给提交按钮 */
  box-sizing: border-box;
}

/* 2. 多图片上传区域 */
.image-upload-container {
  margin-bottom: 32rpx;
}

.image-scroll-view {
  width: 100%;
  white-space: nowrap;
}

.image-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.image-item {
  position: relative;
  width: 220rpx;
  height: 280rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #F3F4F6;
  flex-shrink: 0;
  display: inline-block;
  transition: box-shadow 0.2s;
}

.image-item.selected {
  box-shadow: 0 0 0 6rpx #22C55E;
}

.image-preview {
  width: 100%;
  height: 100%;
  display: block;
}

/* 封面标记 */
.cover-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #22C55E, #16A34A);
  color: white;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
  z-index: 2;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(239, 68, 68, 0.9);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  z-index: 2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.delete-btn:active {
  background: rgba(220, 38, 38, 1);
  transform: scale(0.95);
}

/* 添加按钮 */
.add-image-btn {
  width: 220rpx;
  height: 280rpx;
  border: 3rpx dashed #D1D5DB;
  border-radius: 24rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
  background-color: #F9FAFB;
  flex-shrink: 0;
}

.add-image-btn:active {
  background-color: #F3F4F6;
  border-color: #22C55E;
}

.add-image-btn .icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
  color: #22C55E;
}

.add-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #6B7280;
  margin-bottom: 4rpx;
}

.add-hint {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* 上传提示 */
.upload-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background-color: #F0FDF4;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #16A34A;
}

.upload-tip .icon {
  font-size: 28rpx;
  color: #22C55E;
}

/* 添加植物页图标颜色 */
.icon-back { color: #22C55E; }
.icon-image { color: #8B5CF6; }
.icon-water { color: #3B82F6; }
.icon-plus { color: #22C55E; }
.icon-add { color: #22C55E; }

/* 3. 基础信息区 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 32rpx;
  display: block;
}

.mt-8 { margin-top: 64rpx; }

.info-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-wrapper {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 10rpx;
}

.input-label {
  font-size: 26rpx;
  color: #4B5563;
  margin-left: 0;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.styled-input,
.picker-text {
  width: 100%;
  min-height: 80rpx;
  background-color: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 24rpx;
  padding: 20rpx 18rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.styled-input:focus,
.picker-text:focus {
  border-color: #22C55E;
}

.picker-text {
  height: 48rpx; /* 撑开picker高度 */
  line-height: 48rpx;
}
.placeholder-color { color: #9CA3AF; }

/* 快速选择标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.tag-chip {
  padding: 8rpx 24rpx;
  background-color: #F3F4F6;
  color: #6B7280;
  font-size: 24rpx;
  border-radius: 100rpx;
  transition: all 0.2s ease;
  border: 1rpx solid transparent;
}

.tag-chip:active {
  background-color: #E5E7EB;
}

.tag-chip.active {
  background-color: #F0FDF4;
  color: #16A34A;
  border-color: #BBF7D0;
  font-weight: bold;
}

/* 4. 养护设定区 */
.settings-card {
  background-color: #FFFFFF;
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}
.setting-item.no-border { border-bottom: none; }

.setting-info { display: flex; align-items: center; gap: 24rpx; }

.setting-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
}
.setting-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.bg-blue { background-color: #EFF6FF; color: #3B82F6; }
.bg-orange { background-color: #FFF7ED; color: #F97316; }

.setting-text { display: flex; flex-direction: column; gap: 4rpx;}
.setting-name { font-size: 28rpx; font-weight: bold; color: #374151; }
.setting-desc { font-size: 22rpx; color: #9CA3AF; }

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.step-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #E5E7EB;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #9CA3AF;
  font-size: 32rpx;
}
.step-val { font-size: 32rpx; font-weight: bold; width: 48rpx; text-align: center; }
.text-green { color: #22C55E; border-color: #BBF7D0; background-color: #F0FDF4;}

/* 5. 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 32rpx 48rpx 64rpx;
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
  border-top: 2rpx solid #F9FAFB;
  box-sizing: border-box;
}

.submit-btn {
  width: 100% !important;
  background-color: #22C55E;
  color: white;
  font-weight: bold;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(34, 197, 94, 0.3);
}

.reselect-hint {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%;
  padding: 16rpx 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  justify-content: center;
  align-items: center;
}

.movable-area-box {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0; left: 0;
  overflow: hidden;
}

.movable-img-view {
  display: flex;
}

.crop-hint-bar {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%;
  padding: 12rpx 24rpx;
  background: rgba(0,0,0,0.3);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
  box-sizing: border-box;
}

.crop-hint-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  flex: 1;
  margin-right: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.crop-reselect {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.hidden-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  opacity: 0;
}
