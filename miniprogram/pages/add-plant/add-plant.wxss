/* miniprogram/pages/add-plant/add-plant.wxss */
page {
  background-color: #f8faf8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 1. 顶部导航 */
.nav-header {
  padding: 96rpx 48rpx 32rpx; /* 适配手机状态栏 */
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f8faf8;
  z-index: 100;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  font-size: 40rpx;
  color: #1F2937;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
}

.placeholder-box { width: 64rpx; }

/* 内容滚动区 */
.scroll-content {
  flex: 1;
  padding: 16rpx 48rpx 240rpx; /* 底部留出空间给提交按钮 */
  box-sizing: border-box;
}

/* 2. 照片上传框 */
.photo-upload-box {
  width: 100%;
  height: 360rpx;
  background-color: #F0FDF4;
  border: 4rpx dashed #BBF7D0;
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 64rpx;
  transition: all 0.2s ease;
  overflow: hidden;
  position: relative;
}

.photo-upload-box:active { background-color: #DCFCE7; }
.photo-upload-box.has-img { border: none; }

.uploaded-img { width: 100%; height: 100%; }

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-camera { font-size: 80rpx; margin-bottom: 16rpx; }
.upload-title { font-size: 32rpx; font-weight: bold; color: #16A34A; margin-bottom: 8rpx; }
.upload-subtitle { font-size: 24rpx; color: #4ADE80; }

/* 添加植物页图标颜色 */
.icon-back { color: #22C55E; }
.icon-image { color: #8B5CF6; }
.icon-water { color: #3B82F6; }
.icon-plus { color: #22C55E; }
.icon-add { color: #22C55E; }

/* 3. 基础信息区 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 32rpx;
  display: block;
}

.mt-8 { margin-top: 64rpx; }

.info-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-wrapper {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 10rpx;
}

.input-label {
  font-size: 26rpx;
  color: #4B5563;
  margin-left: 0;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.styled-input,
.picker-text {
  width: 100%;
  min-height: 80rpx;
  background-color: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 24rpx;
  padding: 20rpx 18rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.styled-input:focus,
.picker-text:focus {
  border-color: #22C55E;
}

.picker-text {
  height: 48rpx; /* 撑开picker高度 */
  line-height: 48rpx;
}
.placeholder-color { color: #9CA3AF; }

/* 快速选择标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.tag-chip {
  padding: 8rpx 24rpx;
  background-color: #F3F4F6;
  color: #6B7280;
  font-size: 24rpx;
  border-radius: 100rpx;
  transition: all 0.2s ease;
  border: 1rpx solid transparent;
}

.tag-chip:active {
  background-color: #E5E7EB;
}

.tag-chip.active {
  background-color: #F0FDF4;
  color: #16A34A;
  border-color: #BBF7D0;
  font-weight: bold;
}

/* 4. 养护设定区 */
.settings-card {
  background-color: #FFFFFF;
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}
.setting-item.no-border { border-bottom: none; }

.setting-info { display: flex; align-items: center; gap: 24rpx; }

.setting-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
}
.setting-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.bg-blue { background-color: #EFF6FF; color: #3B82F6; }
.bg-orange { background-color: #FFF7ED; color: #F97316; }

.setting-text { display: flex; flex-direction: column; gap: 4rpx;}
.setting-name { font-size: 28rpx; font-weight: bold; color: #374151; }
.setting-desc { font-size: 22rpx; color: #9CA3AF; }

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.step-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #E5E7EB;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #9CA3AF;
  font-size: 32rpx;
}
.step-val { font-size: 32rpx; font-weight: bold; width: 48rpx; text-align: center; }
.text-green { color: #22C55E; border-color: #BBF7D0; background-color: #F0FDF4;}

/* 5. 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 32rpx 48rpx 64rpx;
  background-color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
  border-top: 2rpx solid #F9FAFB;
  box-sizing: border-box;
}

.submit-btn {
  width: 100% !important;
  background-color: #22C55E;
  color: white;
  font-weight: bold;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(34, 197, 94, 0.3);
}