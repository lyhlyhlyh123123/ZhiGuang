<view class="page-container">

  <!-- 顶部 Hero 区域 -->
  <view class="hero-section">
    <view class="hero-bg-deco">
      <view class="deco-circle deco-circle-1"></view>
      <view class="deco-circle deco-circle-2"></view>
      <view class="deco-leaf">🌿</view>
    </view>
    <view class="header-bar">
      <view class="greeting-box">
        <text class="date-text">{{currentDate}}</text>
        <text class="greeting-title">你好，</text>
        <text class="greeting-name">{{userInfo && userInfo.nickName ? userInfo.nickName : ''}}园丁</text>
      </view>
      <view class="avatar-box" bindtap="handleProfileTap">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo && userInfo.avatarUrl}}"></image>
        <view wx:else class="guest-avatar">
          <text class="icon icon-penzai" style="font-size: 36rpx; color: #22C55E;"></text>
        </view>
        <view class="avatar-ring"></view>
      </view>
    </view>

    <!-- 待办卡片嵌入 Hero -->
    <view class="summary-card {{isTodoFilter ? 'active' : ''}}" bindtap="toggleTodoFilter">
      <view class="summary-left">
        <view class="summary-icon-wrap">
          <text class="icon icon-penzai summary-icon"></text>
        </view>
        <view class="summary-content">
          <text class="summary-label">今日待办</text>
          <block wx:if="{{todoCount > 0}}">
            <text class="summary-title">还有 <text class="summary-count">{{todoCount}}</text> 株待照顾</text>
          </block>
          <block wx:else>
            <text class="summary-title">今日照顾全完成 ✨</text>
          </block>
        </view>
      </view>
      <view class="summary-right">
        <block wx:if="{{todoCount > 0}}">
          <view class="avatar-group">
            <image class="mini-avatar-img" wx:for="{{todoAvatars}}" wx:key="_id" src="{{item.photoFileID}}" mode="aspectFill" lazy-load="{{true}}"></image>
            <view class="mini-avatar-count" wx:if="{{todoCount > 3}}">+{{todoCount - 3}}</view>
          </view>
        </block>
        <block wx:else>
          <view class="all-done-badge">
            <text class="all-done-text">全部完成</text>
          </view>
        </block>
        <view class="filter-tag" wx:if="{{isTodoFilter}}">
          <text>收起</text>
          <text class="icon icon-close" style="font-size: 18rpx;"></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-wrap">
    <view class="search-box {{isTodoFilter ? 'search-box-active' : ''}}">
      <text class="icon icon-search search-icon"></text>
      <input class="search-input" placeholder="{{isTodoFilter ? '正在查看今日待办植物...' : '搜索名称、品种或位置，用 / 联合查询'}}" type="text" bindinput="onSearchInput" value="{{searchKey}}" />
    </view>
  </view>

  <!-- 植物列表区 -->
  <view class="list-section">
    <view class="list-header">
      <view class="list-title-row">
        <view class="list-title-dot"></view>
        <text class="list-title">我的绿植</text>
        <view class="plant-count-badge">拥有 {{allPlants.length || 0}} 株植物</view>
      </view>
    </view>

    <!-- 空状态：无植物 -->
    <view class="empty-state" wx:if="{{noPlants && !noResults}}">
      <view class="empty-illustration">🌱</view>
      <text class="empty-title">还没有植物</text>
      <text class="empty-desc">点击下方 + 按钮，添加你的第一株绿植吧</text>
    </view>

    <!-- 空状态：搜索无结果 -->
    <view class="empty-state" wx:elif="{{noResults}}">
      <view class="empty-illustration">🔍</view>
      <text class="empty-title">没找到相关植物</text>
      <text class="empty-desc">试试换个关键词搜索吧～</text>
    </view>

    <!-- 植物卡片网格 -->
    <view class="plant-grid" wx:elif="{{plantList.length > 0}}">
      <view class="plant-card" wx:for="{{plantList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
        <!-- 图片区（纯净，无遮挡） -->
        <view class="card-img-box">
          <image class="card-img" src="{{item.photoFileID}}" mode="aspectFill" lazy-load binderror="onImageError" data-id="{{item._id}}"></image>
        </view>
        <!-- 信息区 -->
        <view class="card-body">
          <view class="card-name-row">
            <text class="card-name">{{item.nickname}}</text>
            <view class="card-species-tag">
              <text class="icon icon-penzai" style="font-size: 18rpx; color: #22C55E; margin-right: 4rpx;"></text>
              <text class="card-species-text">{{item.species || '未知'}}</text>
            </view>
          </view>
          <!-- 地点行 -->
          <view class="card-location-row" wx:if="{{item.location}}">
            <text class="icon icon-yunshudidian card-loc-icon" style="color: #22C55E;"></text>
            <text class="card-loc-text">{{item.location}}</text>
          </view>
          <view class="card-divider"></view>
          <view class="card-footer">
            <view class="card-date-row">
              <text class="icon icon-riqi card-date-icon"></text>
              <text class="card-date">{{item.adoptDate}}</text>
            </view>
            <!-- 浇水倒计时 -->
            <view class="water-badge {{item.waterCountdown <= 0 ? 'water-badge-urgent' : ''}}">
              <text class="icon icon-water water-badge-icon"></text>
              <text class="water-badge-text" wx:if="{{item.waterCountdown > 0}}">{{item.waterCountdown}}天后</text>
              <text class="water-badge-text" wx:elif="{{item.waterCountdown === 0}}">今天浇</text>
              <text class="water-badge-text" wx:else>逾期{{-item.waterCountdown}}天</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 分页 -->
    <view class="pagination" wx:if="{{!noResults && filteredPlants.length > pageSize}}">
      <button class="page-btn" bindtap="onPrevPage" disabled="{{page <= 1}}">上一页</button>
      <text class="page-info">{{page}} / {{totalPages}}</text>
      <button class="page-btn" bindtap="onNextPage" disabled="{{page >= totalPages}}">下一页</button>
    </view>
  </view>


</view>
