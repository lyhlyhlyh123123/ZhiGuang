/* miniprogram/pages/index/index.wxss */
page {
  background-color: #f8faf8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page-container {
  padding: 48rpx 40rpx 200rpx;
  box-sizing: border-box;
}

/* 1. 顶部状态栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.greeting-box {
  display: flex;
  flex-direction: column;
}

.date-text {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.greeting-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1F2937;
}

.avatar-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #BBF7D0;
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #F0FDF4;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.avatar-box .icon {
  font-size: 40rpx;
  color: #22C55E;
}

/* 首页图标颜色 */
.icon-search { color: #6B7280; }
.icon-Scissors { color: #10B981; }
.icon-penzai { color: #22C55E; }
.icon-close { color: #6B7280; }
.icon-riqi { color: #F59E0B; }
.icon-add { color: #FFFFFF; }
.icon-image { color: #8B5CF6; }
.icon-arrow-left-bold { color: #22C55E; }

/* 2. 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 48rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 32rpx;
  padding: 0 18rpx;
  min-height: 80rpx;
  box-sizing: border-box;
}

.search-icon {
  position: static;
  margin-right: 6rpx;
  font-size: 28rpx;
  color: #2D3748;
}

.search-input {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background-color: transparent;
  border: none;
  outline: none;
  padding: 0;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #374151;
}

.search-input::placeholder {
  color: #9CA3AF;
}


/* 3. 渐变概要卡片 */
.summary-card {
  background: linear-gradient(to right, #22C55E, #16A34A);
  border-radius: 48rpx;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(34, 197, 94, 0.2);
  margin-bottom: 48rpx;
  transition: all 0.3s ease;
  border: 4rpx solid transparent;
}

.summary-card.active {
  border-color: #FFFFFF;
  transform: translateY(-4rpx);
  box-shadow: 0 30rpx 60rpx rgba(34, 197, 94, 0.4);
}

.filter-indicator {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
}

.bg-waterdrop {
  position: absolute;
  right: -40rpx;
  bottom: -40rpx;
  font-size: 240rpx;
  color: rgba(255, 255, 255, 0.2);
}

.summary-content {
  position: relative;
  z-index: 10;
}

.summary-label {
  font-size: 24rpx;
  color: #DCFCE7;
  display: block;
  margin-bottom: 8rpx;
}

.summary-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
  margin-bottom: 32rpx;
}

.success-tip {
  font-size: 26rpx;
  color: #DCFCE7;
  font-weight: 500;
}

.avatar-group {
  display: flex;
  align-items: center;
}

.mini-avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #22C55E;
  background-color: #FFFFFF;
  margin-left: -20rpx;
}

.mini-avatar-img:first-child {
  margin-left: 0;
}

.mini-avatar.count {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #22C55E;
  background-color: #FFFFFF;
  margin-left: -20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #16A34A;
  font-weight: bold;
  font-size: 20rpx;
  z-index: 5;
}

/* 4. 植物列表 */
.list-header {
  margin-bottom: 32rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #374151;
}

.plant-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.plant-card {
  background-color: #FFFFFF;
  border: 2rpx solid #F3F4F6;
  border-radius: 40rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  transition: all 0.2s ease;
}

.plant-card:active {
  transform: scale(0.96);
}

.card-img-box {
  width: 100%;
  height: 240rpx;
  border-radius: 28rpx;
  background-color: #EFF6FF;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.card-img {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  backdrop-filter: blur(8px);
}

.status-badge.bg-blue {
  background-color: rgba(255, 255, 255, 0.8);
  color: #2563EB;
}

.card-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-desc {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 16rpx;
}

.card-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #6B7280;
}

.card-action .icon {
  font-size: 20rpx;
  color: #22C55E; /* ✨ 将日期图标改为绿色 */
}

.action-date {
  font-size: 22rpx;
  color: #4B5563;
}

.empty-state {
  text-align: center;
  color: #6B7280;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 30rpx;
}

.page-btn {
  background-color: #43A047;
  color: #FFFFFF;
  border: none;
  border-radius: 18rpx;
  padding: 14rpx 24rpx;
}

.page-info {
  font-size: 26rpx;
  color: #374151;
}

.action-icon {
  margin-right: 8rpx;
}

/* 悬浮添加按钮 */
.fab-add-btn {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 112rpx;
  height: 112rpx;
  background-color: #22C55E;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 16rpx 32rpx rgba(34, 197, 94, 0.3);
  border: 6rpx solid #FFFFFF;
  z-index: 100;
}

.fab-add-text {
  color: #FFFFFF;
  font-size: 70rpx;
  font-weight: 100;
  line-height: 1;
  margin-top: -8rpx;
}

.fab-icon {
  color: #FFFFFF;
  font-size: 60rpx;
  font-weight: 300;
  margin-top: -6rpx;
}

/* 6. 高级感登录遮罩层 */
.login-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.login-overlay.show {
  opacity: 1;
  visibility: visible;
}

.login-glass-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(240, 253, 244, 0.9) 0%, rgba(220, 252, 231, 0.95) 100%);
  backdrop-filter: blur(40rpx);
}

.login-content-card {
  position: relative;
  width: 85%;
  background: #FFFFFF;
  border-radius: 64rpx;
  padding: 80rpx 48rpx 60rpx;
  box-shadow: 0 40rpx 80rpx rgba(22, 101, 52, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateY(60rpx);
  transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.login-overlay.show .login-content-card {
  transform: translateY(0);
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  background-color: #F0FDF4;
  border-radius: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(34, 197, 94, 0.1);
  transform: rotate(-10deg);
}

.brand-logo .icon {
  font-size: 80rpx;
  color: #22C55E;
}

/* 品牌页图标 */
.brand-icon { font-size: 80rpx; color: #22C55E; }

.brand-name {
  font-size: 44rpx;
  font-weight: 900;
  color: #166534;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 24rpx;
  color: #86A789;
  letter-spacing: 1rpx;
}

.form-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.avatar-select-btn {
  background: none;
  padding: 0;
  width: 180rpx !important;
  height: 180rpx !important;
  border-radius: 50%;
  position: relative;
  margin-bottom: 16rpx;
  border: 4rpx solid #F0FDF4;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #E8F5E9;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background-color: #22C55E;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 4rpx solid #FFFFFF;
}

.avatar-badge .icon {
  font-size: 28rpx;
  color: #FFFFFF;
}

/* 徽章图标 */
.badge-icon { font-size: 28rpx; color: #FFFFFF; }

.form-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 48rpx;
}

.input-container {
  width: 100%;
  background-color: #F9FAFB;
  border-radius: 32rpx;
  padding: 24rpx 40rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #F3F4F6;
}

.input-label {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 600;
}

.start-journey-btn {
  width: 100% !important;
  height: 110rpx;
  background: #E5E7EB;
  color: #9CA3AF;
  border-radius: 55rpx;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
  margin-bottom: 32rpx;
}

.start-journey-btn.active {
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  color: #FFFFFF;
  box-shadow: 0 20rpx 40rpx rgba(34, 197, 94, 0.25);
}

.start-journey-btn.active:active {
  transform: scale(0.97);
}

.privacy-tip {
  font-size: 20rpx;
  color: #D1D5DB;
}


