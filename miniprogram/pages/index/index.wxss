/* pages/index/index.wxss */
page {
  background-color: #F0FDF4;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page-container {
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* ===================== Hero 区域 ===================== */
.hero-section {
  background: linear-gradient(160deg, #166534 0%, #15803D 50%, #22C55E 100%);
  padding: 60rpx 40rpx 48rpx;
  position: relative;
  overflow: hidden;
  border-radius: 0 0 60rpx 60rpx;
  margin-bottom: 32rpx;
}

/* 背景装饰圆 */
.hero-bg-deco {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.deco-circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -120rpx;
  right: -80rpx;
}

.deco-circle-2 {
  width: 240rpx;
  height: 240rpx;
  bottom: -60rpx;
  left: -40rpx;
}

.deco-leaf {
  position: absolute;
  right: 48rpx;
  bottom: 100rpx;
  font-size: 120rpx;
  opacity: 0.15;
  transform: rotate(20deg);
}

/* 顶部 header */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.greeting-box {
  display: flex;
  flex-direction: column;
}

.date-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.greeting-title {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

.greeting-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-top: 4rpx;
}

/* 头像 */
.avatar-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.avatar-ring {
  position: absolute;
  top: -6rpx; left: -6rpx;
  width: calc(100% + 12rpx);
  height: calc(100% + 12rpx);
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  pointer-events: none;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.guest-avatar {
  width: 100%;
  height: 100%;
  background: rgba(255,255,255,0.2);
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
}

.guest-dot {
  position: absolute;
  top: 0; right: 0;
  width: 20rpx;
  height: 20rpx;
  background: #EF4444;
  border-radius: 50%;
  border: 3rpx solid #166534;
}

.avatar-box .icon {
  font-size: 44rpx;
  color: #22C55E;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
  background: rgba(255,255,255,0.15);
}

/* ===================== 待办卡片 ===================== */
.summary-card {
  background: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 36rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10px);
  transition: all 0.25s ease;
}

.summary-card.active {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.5);
}

.summary-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.summary-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.summary-icon {
  font-size: 44rpx;
  color: #FFFFFF;
}

.summary-content {
  display: flex;
  flex-direction: column;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 6rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.summary-count {
  font-size: 36rpx;
  font-weight: 900;
  color: #FDE68A;
}

.summary-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.avatar-group {
  display: flex;
  align-items: center;
}

.mini-avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.8);
  margin-left: -16rpx;
  background: #DCFCE7;
}

.mini-avatar-img:first-child {
  margin-left: 0;
}

.mini-avatar-count {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  margin-left: -16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: bold;
}

.all-done-badge {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}

.all-done-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 16rpx;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  color: #FFFFFF;
}

/* ===================== 搜索框 ===================== */
.search-wrap {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 32rpx;
  padding: 0 28rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: border-color 0.2s ease;
}

.search-box.search-box-active {
  border-color: #22C55E;
  background-color: #F0FDF4;
}

.search-icon {
  font-size: 30rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background-color: transparent;
  border: none;
  font-size: 28rpx;
  color: #374151;
}

/* ===================== 列表区 ===================== */
.list-section {
  padding: 0 32rpx;
}

.list-header {
  margin-bottom: 28rpx;
}

.list-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.list-title-dot {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(to bottom, #22C55E, #16A34A);
  border-radius: 4rpx;
}

.list-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1F2937;
  flex: 1;
}

.plant-count-badge {
  background: #DCFCE7;
  color: #16A34A;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ===================== 空状态 ===================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-illustration {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.6;
}

/* ===================== 植物卡片 ===================== */
.plant-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.plant-card {
  background-color: #FFFFFF;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease;
  border: 2rpx solid #F0FDF4;
}

.plant-card:active {
  transform: scale(0.97);
}

.card-img-box {
  width: 100%;
  padding-top: 100%; /* 1:1 正方形比例,参考小红书 */
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #DCFCE7, #BBF7D0);
}

.card-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* 确保图片覆盖容器且居中裁剪 */
}

/* 卡片信息区 */
.card-body {
  padding: 20rpx 24rpx 22rpx;
}

.card-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1F2937;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-species-tag {
  display: flex;
  align-items: center;
  background: #F0FDF4;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
  max-width: 120rpx;
}

.card-species-text {
  font-size: 18rpx;
  color: #16A34A;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 地点行 */
.card-location-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 14rpx;
}

.card-loc-icon {
  font-size: 24rpx;
  color: #22C55E;
  flex-shrink: 0;
}

.card-loc-text {
  font-size: 22rpx;
  color: #6B7280;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-divider {
  height: 1rpx;
  background: #F3F4F6;
  margin-bottom: 14rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-date-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.card-date-icon {
  font-size: 22rpx;
  color: #22C55E;
}

.card-date {
  font-size: 22rpx;
  color: #6B7280;
}

.card-arrow {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #22C55E, #16A34A);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-arrow .icon {
  color: #FFFFFF;
  font-size: 20rpx;
  transform: rotate(180deg);
  display: block;
}

/* 浇水倒计时徽章 */
.water-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #F0FDF4;
  border: 1rpx solid #BBF7D0;
  border-radius: 16rpx;
  padding: 6rpx 14rpx;
}

.water-badge-urgent {
  background: #FFF7ED;
  border-color: #FED7AA;
}

.water-badge-icon {
  font-size: 20rpx;
  color: #22C55E;
}

.water-badge-urgent .water-badge-icon {
  color: #F97316;
}

.water-badge-text {
  font-size: 20rpx;
  color: #16A34A;
  font-weight: 600;
}

.water-badge-urgent .water-badge-text {
  color: #F97316;
}

/* ===================== 分页 ===================== */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  margin-top: 40rpx;
}

.page-btn {
  background: #FFFFFF;
  color: #16A34A;
  border: 2rpx solid #BBF7D0;
  border-radius: 24rpx;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.page-btn[disabled] {
  color: #D1D5DB;
  border-color: #F3F4F6;
}

.page-info {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
}

/* ===================== 悬浮按钮 ===================== */
.fab-add-btn {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #22C55E, #16A34A);
  border-radius: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(34, 197, 94, 0.4);
  border: 6rpx solid #FFFFFF;
  z-index: 100;
}

.fab-add-text {
  color: #FFFFFF;
  font-size: 72rpx;
  font-weight: 100;
  line-height: 1;
  margin-top: -8rpx;
}

/* ===================== 图标颜色 ===================== */
.icon-search { color: #9CA3AF; }
.icon-Scissors { color: #22C55E; }
.icon-penzai { color: #22C55E; }
.icon-close { color: rgba(255,255,255,0.8); }
.icon-riqi { color: #22C55E; }
.icon-yunshudidian { color: #22C55E; }
.icon-add { color: #FFFFFF; }
.icon-image { color: #FFFFFF; }
.icon-arrow-left-bold { color: #22C55E; }