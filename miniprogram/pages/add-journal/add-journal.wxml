<view class="page-container">
  <view class="nav-header">
    <view class="back-btn" bindtap="goBack">
      <text class="icon icon-back"></text>
    </view>
    <text class="nav-title">{{editMode ? '编辑' : '记录'}} {{plantName}} 的成长</text>
    <view class="placeholder-box"></view>
  </view>
  <scroll-view scroll-y class="scroll-content">
    <view class="section-title">记录对象</view>
    <view class="selected-plant-card">
      <view class="plant-info-display">
        <text class="plant-name-label">正在记录：</text>
        <text class="plant-name-value">{{plantName}}</text>
      </view>
    </view>

    <view class="section-title">做了哪些事？(可多选)</view>
  <swiper class="action-swiper" indicator-dots indicator-color="rgba(0,0,0,0.3)" indicator-active-color="#22C55E" circular autoplay="{{false}}">
    <!-- 第1页：前4个操作 -->
    <swiper-item>
      <view class="action-grid">
        <view
          class="action-item {{item.selected ? 'active' : ''}}"
          wx:for="{{actions}}" wx:for-index="idx"
          wx:key="value"
          wx:if="{{idx < 4}}"
          bindtap="toggleAction"
          bindlongpress="longPressAction"
          data-index="{{idx}}"
        >
          <text class="action-icon icon {{item.icon}}"></text>
          <text class="action-label">{{item.label}}</text>
          <text wx:if="{{item.isCustom}}" class="custom-hint">长按编辑</text>
          <view class="check-badge" wx:if="{{item.selected}}">
            <text class="icon icon-plus" style="font-size: 16rpx; color: #fff;"></text>
          </view>
        </view>
      </view>
    </swiper-item>
    
    <!-- 第2页：后4个操作 -->
    <swiper-item>
      <view class="action-grid">
        <view
          class="action-item {{item.selected ? 'active' : ''}}"
          wx:for="{{actions}}" wx:for-index="idx"
          wx:key="value"
          wx:if="{{idx >= 4}}"
          bindtap="toggleAction"
          bindlongpress="longPressAction"
          data-index="{{idx}}"
        >
          <text class="action-icon icon {{item.icon}}"></text>
          <text class="action-label">{{item.label}}</text>
          <text wx:if="{{item.isCustom}}" class="custom-hint">长按编辑</text>
          <view class="check-badge" wx:if="{{item.selected}}">
            <text class="icon icon-plus" style="font-size: 16rpx; color: #fff;"></text>
          </view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="section-title">上传瞬间 (最多 9 张)</view>
  <view class="image-list">
    <view class="image-wrapper" wx:for="{{tempImagePaths}}" wx:key="index">
      <image 
        class="image-wrapper-img"
        src="{{item}}" 
        mode="aspectFill"
        lazy-load
        bindtap="previewImage" 
        data-url="{{item}}"
      ></image>
      <view class="delete-img" catchtap="deleteImage" data-index="{{index}}">
        <text class="icon icon-close" style="font-size: 24rpx; color: #fff;"></text>
      </view>
    </view>
    
    <view class="add-img-btn" bindtap="chooseImage" wx:if="{{tempImagePaths.length < 9}}">
      <view class="add-img-btn-inner">
        <text class="plus icon icon-plus"></text>
        <text class="add-img-count">{{tempImagePaths.length}}/9</text>
      </view>
    </view>
  </view>

  <view class="section-title">记录时间 (可选)</view>
  <view class="time-picker-section">
    <picker mode="date" value="{{selectedDate}}" end="{{currentDate}}" bindchange="onDateChange">
      <view class="picker-item">
        <text class="picker-label">日期</text>
        <view class="picker-value">
          <text>{{selectedDate || '选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
    </picker>
    <picker mode="time" value="{{selectedTime}}" bindchange="onTimeChange">
      <view class="picker-item">
        <text class="picker-label">时间</text>
        <view class="picker-value">
          <text>{{selectedTime || '选择时间'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
    </picker>
    <view class="time-hint">不填写则默认为当前时间</view>
  </view>

  <view class="section-title">想说的话</view>
  <view class="input-card">
    <textarea placeholder="描述下此刻的心情..." value="{{note}}" bindinput="onNoteInput" maxlength="200" class="diary-input"></textarea>
    <view class="word-count">{{note.length || 0}} / 200</view>
  </view>

  <button class="save-btn" bindtap="submitJournal">{{editMode ? '更新记录' : '保存这条动态'}}</button>
  </scroll-view>
</view>