<view class="page">

  <!-- 顶部操作栏 -->
  <view class="top-bar">
    <text class="section-title">选择植物</text>
    <view class="top-bar-right">
      <text class="count-badge">已选 {{selectedIds.length}} 株</text>
      <view class="sel-btn" bindtap="selectAll">全选</view>
      <view class="sel-btn" bindtap="clearAll">清空</view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="batch-search-box">
    <text class="icon icon-search" style="font-size: 28rpx; color: #9CA3AF; flex-shrink: 0;"></text>
    <input
      class="batch-search-input"
      placeholder="搜索名字、品种或位置，用 / 联合查询"
      value="{{batchSearchKey}}"
      bindinput="onBatchSearch"
    />
    <text class="batch-search-clear" wx:if="{{batchSearchKey}}" bindtap="clearBatchSearch">✕</text>
  </view>

  <!-- 植物横向滚动选择 -->
  <scroll-view scroll-x class="plant-scroll" enhanced show-scrollbar="{{false}}">
    <view class="plant-scroll-inner">
      <view
        class="plant-scroll-card {{item._selected ? 'selected' : ''}}"
        wx:for="{{displayList}}" wx:key="_id"
        bindtap="togglePlant" data-id="{{item._id}}"
      >
        <view class="scroll-img-wrap">
          <image class="scroll-img" src="{{item.photoFileID}}" mode="aspectFill"></image>
        </view>
        <text class="scroll-name">{{item.nickname}}</text>
        <text class="scroll-sub" wx:if="{{item.species || item.location}}">{{item.species}}{{item.species && item.location ? ' · ' : ''}}{{item.location}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 选择操作 -->
  <view class="section-title" style="margin-top: 16rpx;">选择操作</view>
  <swiper class="action-swiper" indicator-dots indicator-color="rgba(0,0,0,0.3)" indicator-active-color="#22C55E" circular autoplay="{{false}}">
    <!-- 第1页：前4个操作 -->
    <swiper-item>
      <view class="action-grid">
        <view
          class="action-item {{item.selected ? 'active' : ''}}"
          wx:for="{{actions}}" wx:for-index="idx" wx:key="value"
          wx:if="{{idx < 4}}"
          bindtap="toggleAction"
          bindlongpress="longPressAction"
          data-index="{{idx}}"
        >
          <text class="iconfont {{item.icon}} action-icon"></text>
          <text class="action-label">{{item.label}}</text>
          <text wx:if="{{item.isCustom}}" class="custom-hint">长按编辑</text>
        </view>
      </view>
    </swiper-item>
    
    <!-- 第2页：后4个操作 -->
    <swiper-item>
      <view class="action-grid">
        <view
          class="action-item {{item.selected ? 'active' : ''}}"
          wx:for="{{actions}}" wx:for-index="idx" wx:key="value"
          wx:if="{{idx >= 4}}"
          bindtap="toggleAction"
          bindlongpress="longPressAction"
          data-index="{{idx}}"
        >
          <text class="iconfont {{item.icon}} action-icon"></text>
          <text class="action-label">{{item.label}}</text>
          <text wx:if="{{item.isCustom}}" class="custom-hint">长按编辑</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 备注 -->
  <view class="section-title" style="margin-top: 16rpx;">备注（可选）</view>
  <view class="note-card">
    <textarea class="note-input" placeholder="批量养护备注..." value="{{note}}" bindinput="onNoteInput" maxlength="100"></textarea>
  </view>

  <button class="submit-btn {{selectedIds.length > 0 ? 'active' : ''}}" bindtap="submitBatch">
    确认记录 {{selectedIds.length > 0 ? selectedIds.length + ' 株' : ''}}
  </button>

</view>
