<view class="page-container">
  
  <!-- 骨架屏：加载中 -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skeleton-hero"></view>
    <view class="skeleton-card">
      <view class="skeleton-line skeleton-title"></view>
      <view class="skeleton-tags">
        <view class="skeleton-tag"></view>
        <view class="skeleton-tag"></view>
        <view class="skeleton-tag"></view>
      </view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line skeleton-short"></view>
    </view>
  </view>

  <!-- 正式内容 -->
  <block wx:else>
  <!-- 轮播图区域 -->
  <view class="hero-section">
    <swiper
      class="plant-swiper"
      style="height: {{swiperHeight}}rpx; transition: height 0.3s ease;"
      indicator-dots="{{false}}"
      autoplay="{{false}}"
      circular="{{plantPhotos.length > 1}}"
      wx:if="{{plantPhotos.length > 0}}"
      bindchange="onSwiperChange"
      current="{{currentPhotoIndex}}"
    >
      <swiper-item wx:for="{{plantPhotos}}" wx:key="*this" wx:for-index="idx">
        <view class="swiper-image-wrapper">
          <image
            class="hero-bg"
            src="{{item}}"
            mode="widthFix"
            bindload="onImageLoad"
            bindtap="previewImage"
            data-current="{{item}}"
            data-index="{{idx}}"
            lazy-load="{{idx > 2}}"
          />
        </view>
      </swiper-item>
    </swiper>
    <!-- 图片计数器 -->
    <view class="photo-counter" wx:if="{{plantPhotos.length > 1}}">
      <text>{{currentPhotoIndex + 1}}/{{plantPhotos.length}}</text>
    </view>
    <!-- 自定义切换点（图片下方） -->
    <view class="custom-dots" wx:if="{{plantPhotos.length > 1}}">
      <view
        wx:for="{{plantPhotos}}"
        wx:key="index"
        class="dot {{index === currentPhotoIndex ? 'active' : ''}}"
      ></view>
    </view>
  </view>

  <view class="content-card">
  
    <!-- 植物信息展示区 -->
    <view class="plant-info-section" wx:if="{{plantInfo}}">
        <!-- 名字和操作按钮行 -->
        <view class="plant-name-row">
          <view style="display:flex;align-items:center;gap:12rpx;flex:1;min-width:0;">
            <text class="plant-name">{{plantInfo.nickname}}</text>
          </view>
          <view class="name-actions">
            <!-- 点赞按钮（图标右上角显示数字） -->
            <view class="like-btn-wrapper" bindtap="toggleLike">
              <view class="action-icon-btn like-btn {{hasLiked ? 'liked' : ''}}">
                <text class="iconfont icon-icon"></text>
              </view>
              <text class="like-badge">{{likeCount}}</text>
            </view>
            <!-- 编辑按钮（仅所有者可见，纯图标） -->
            <view wx:if="{{isOwner}}" class="action-icon-btn edit-btn" bindtap="goToEditPlant">
              <text class="iconfont icon-edit"></text>
            </view>
            <!-- 删除按钮（仅所有者可见，纯图标） -->
            <view wx:if="{{isOwner}}" class="action-icon-btn delete-btn" bindtap="confirmDelete">
              <text class="iconfont icon-delete"></text>
            </view>
          </view>
        </view>
        <!-- 种类行 -->
        <view class="plant-species-row">
          <text class="plant-species">{{plantInfo.species}}</text>
        </view>
        <!-- 分隔线 -->
        <view class="divider-line"></view>
      
      <!-- 信息卡片轮播（添加箭头包裹容器） -->
      <view class="info-swiper-wrapper">
        <swiper class="info-swiper" indicator-dots="{{false}}" circular>
        
        <!-- 第1页：位置、陪伴、亲密度（三列） -->
        <swiper-item>
          <view class="swiper-card">
            <view class="card-three-col">
              <view class="col-item">
                <view class="col-header">
                  <text class="col-icon iconfont icon-yunshudidian"></text>
                  <text class="col-label">位置</text>
                </view>
                <text class="col-value">{{plantInfo.location || '未设置'}}</text>
              </view>
              <view class="col-item">
                <view class="col-header">
                  <text class="col-icon iconfont icon-calendar"></text>
                  <text class="col-label">陪伴</text>
                </view>
                <text wx:if="{{isDead}}" class="col-value col-dead-label">结束陪伴</text>
                <text wx:else class="col-value">{{adoptDays}}天</text>
              </view>
              <view class="col-item">
                <view class="col-header">
                  <text class="col-icon iconfont icon-heart"></text>
                  <text class="col-label">亲密度</text>
                </view>
                <text class="col-value highlight">{{intimacy}}%</text>
              </view>
            </view>
          </view>
        </swiper-item>

        <!-- 第2页：来源 -->
        <swiper-item>
          <view class="swiper-card">
            <view class="card-single" bindtap="showFullSource">
              <view class="single-header">
                <text class="single-icon iconfont icon-laiyuan"></text>
                <text class="single-label">来源</text>
              </view>
              <text class="single-value">{{plantInfo.source || '无'}}</text>
            </view>
          </view>
        </swiper-item>

        <!-- 第3页：备注 -->
        <swiper-item>
          <view class="swiper-card">
            <view class="card-single" bindtap="showFullRemark">
              <view class="single-header">
                <text class="single-icon iconfont icon-beizhu"></text>
                <text class="single-label">备注</text>
              </view>
              <text class="single-value">{{plantInfo.remark || '无'}}</text>
            </view>
          </view>
        </swiper-item>

      </swiper>
        <!-- 右侧箭头 -->
        <text class="swiper-arrow">›</text>
      </view>
    </view>

    <!-- 养护信息分隔区 -->
    <view class="care-divider" wx:if="{{careTasksDisplay.length > 0 && !isDead}}"></view>

    <!-- 养护标题 -->
    <view class="care-title" wx:if="{{careTasksDisplay.length > 0 && !isDead}}">养护计划</view>

    <!-- 养护信息区（swiper滑动，仅多任务时可滑） -->
    <view class="care-swiper-wrapper" wx:if="{{careTasksDisplay.length > 0 && !isDead}}">
      <swiper class="care-swiper" indicator-dots="{{false}}" circular="{{false}}" autoplay="{{false}}">
        <swiper-item wx:for="{{careTasksDisplay}}" wx:key="name">
          <view class="care-group">
            <view class="care-card-item">
              <view class="care-card-icon-wrap" style="background:{{item.iconBg}};">
                <text class="care-card-icon iconfont {{item.icon}}" style="color:{{item.iconColor}};"></text>
              </view>
              <view class="care-card-text">
                <text class="care-card-label">{{item.name}}周期</text>
                <text class="care-card-value">{{item.interval}}天/次</text>
              </view>
            </view>
            <view class="care-card-item">
              <view class="care-card-icon-wrap" style="background:#FFF7ED;">
                <text class="iconfont icon-riqi1 care-card-icon" style="color:#F59E0B;font-size:45rpx;"></text>
              </view>
              <view class="care-card-text">
                <text class="care-card-label">下次{{item.name}}</text>
                <text class="care-card-value {{item.isOverdue ? 'warn' : ''}}">{{item.nextDateStr}}</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <text wx:if="{{careTasksDisplay.length > 1}}" class="swiper-arrow">›</text>
    </view>

    <view class="timeline-header">
      <text class="timeline-title">{{isDead ? '成长回忆' : '养成日记'}}</text>
    </view>

    <view class="timeline-list" wx:if="{{journalList.length > 0}}">
      <view class="timeline-item" wx:for="{{journalList}}" wx:key="_id">
        <view class="timeline-axis">
          <view class="timeline-line"></view>
            <view class="timeline-dot {{item.renderPhotoList && item.renderPhotoList.length > 0 ? 'bg-blue' : 'bg-green'}}">
                <text wx:if="{{item.renderPhotoList && item.renderPhotoList.length > 0}}" class="icon icon-image"></text>
                <text wx:else class="icon icon-jilu"></text>
            </view>
        </view>
        <view class="timeline-content">
          <view class="timeline-card" bindlongpress="{{isOwner ? 'deleteJournal' : ''}}" data-id="{{item._id}}" data-index="{{index}}">
            <view class="card-header">
              <!-- 渲染动作标签列表 -->
              <view class="action-tag-list" wx:if="{{item.renderActions && item.renderActions.length > 0}}">
                <view class="action-tag" wx:for="{{item.renderActions}}" wx:for-item="action" wx:key="label">
                  <text class="iconfont {{action.icon}} action-tag-icon"></text>
                  <text class="action-label">{{action.label}}</text>
                </view>
              </view>
              <text class="action-title" wx:else>记录成长</text>
              <text class="action-date">{{item.formatTime}}</text>
            </view>
            <text class="action-note" wx:if="{{item.note}}">{{item.note}}</text>
            
            <view class="photo-preview" wx:if="{{item.renderPhotoList && item.renderPhotoList.length > 0}}">
                <view class="journal-img-wrapper" wx:for="{{item.renderPhotoList}}" wx:for-item="img" wx:key="*this" bindtap="previewJournalImg" data-current="{{img}}" data-list="{{item.renderPhotoList}}">
                  <image class="journal-img" src="{{img}}" mode="aspectFill"></image>
                </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text>还没有记录哦，快去添加吧~</text>
    </view>

  </view>

  <view class="bottom-action-bar" wx:if="{{isOwner && !isDead}}">
    <button class="btn-record" bindtap="openJournalPage">
      <text class="btn-icon icon icon-jilu"></text>
      <text class="btn-text">记录植物成长</text>
    </button>
    <button class="btn-share" open-type="share">
      <text class="btn-icon icon icon-share"></text>
      <text class="btn-text">分享植物获赞</text>
    </button>
  </view>

  </block>

</view>