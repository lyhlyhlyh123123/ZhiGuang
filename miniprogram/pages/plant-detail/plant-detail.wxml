<view class="page-container">
  
  <!-- 骨架屏：加载中 -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skeleton-hero"></view>
    <view class="skeleton-card">
      <view class="skeleton-line skeleton-title"></view>
      <view class="skeleton-tags">
        <view class="skeleton-tag"></view>
        <view class="skeleton-tag"></view>
        <view class="skeleton-tag"></view>
      </view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line skeleton-short"></view>
    </view>
  </view>

  <!-- 正式内容 -->
  <block wx:else>
  <!-- 轮播图区域 -->
  <view class="hero-section">
    <swiper
      class="plant-swiper"
      indicator-dots="{{plantPhotos.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#22C55E"
      autoplay="{{false}}"
      circular="{{plantPhotos.length > 1}}"
      wx:if="{{plantPhotos.length > 0}}"
    >
      <swiper-item wx:for="{{plantPhotos}}" wx:key="*this">
        <image
          class="hero-bg"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-current="{{item}}"
        />
      </swiper-item>
    </swiper>
    <!-- 图片计数器 -->
    <view class="photo-counter" wx:if="{{plantPhotos.length > 1}}">
      <text class="icon icon-image"></text>
      <text>{{plantPhotos.length}}张</text>
    </view>
  </view>

  <view class="content-card">
  
    <!-- 植物信息展示区 -->
    <view class="plant-info-section" wx:if="{{plantInfo}}">
        <view class="plant-name-row">
          <view class="name-with-icon">
            <text class="plant-icon iconfont icon-xiugaimingcheng"></text>
            <text class="plant-name">{{plantInfo.nickname}}</text>
            <text class="species-icon iconfont icon-penzai"></text>
            <text class="plant-latin">{{plantInfo.species}}</text>
          </view>
          <view class="name-actions">
            <!-- 点赞按钮 -->
            <view class="like-button-mini {{hasLiked ? 'liked' : ''}}" bindtap="toggleLike">
              <text class="like-icon-mini iconfont icon-icon"></text>
              <text class="like-count-mini">{{likeCount}}</text>
            </view>
            <!-- 编辑和删除按钮（仅所有者可见） -->
            <view wx:if="{{isOwner}}" class="edit-btn btn-primary" bindtap="goToEditPlant">
              <text class="edit-text">编辑</text>
            </view>
            <view wx:if="{{isOwner}}" class="edit-btn btn-danger" bindtap="confirmDelete">
              <text class="iconfont icon-delete edit-text"></text>
            </view>
          </view>
        </view>
      
      <!-- 信息卡片轮播 -->
      <swiper class="info-swiper" indicator-dots indicator-color="rgba(0,0,0,0.3)" indicator-active-color="#22C55E" circular>
        
        <!-- 第1页：位置、陪伴、亲密度（三列） -->
        <swiper-item>
          <view class="swiper-card">
            <view class="card-three-col">
              <view class="col-item">
                <text class="col-icon iconfont icon-yunshudidian"></text>
                <text class="col-label">位置</text>
                <text class="col-value">{{plantInfo.location || '未设置'}}</text>
              </view>
              <view class="col-item">
                <text class="col-icon iconfont icon-calendar"></text>
                <text class="col-label">陪伴</text>
                <text class="col-value">{{adoptDays}}天</text>
              </view>
              <view class="col-item">
                <text class="col-icon iconfont icon-heart"></text>
                <text class="col-label">亲密度</text>
                <text class="col-value highlight">{{intimacy}}%</text>
              </view>
            </view>
          </view>
        </swiper-item>

        <!-- 第2页：来源 -->
        <swiper-item>
          <view class="swiper-card">
            <view class="card-single">
              <text class="single-icon iconfont icon-laiyuan"></text>
              <text class="single-label">来源</text>
              <text class="single-value">{{plantInfo.source || '无'}}</text>
            </view>
          </view>
        </swiper-item>

        <!-- 第3页：备注 -->
        <swiper-item>
          <view class="swiper-card">
            <view class="card-single" bindtap="showFullRemark">
              <text class="single-icon iconfont icon-beizhu"></text>
              <text class="single-label">备注</text>
              <text class="single-value">{{plantInfo.remark || '无'}}</text>
            </view>
          </view>
        </swiper-item>

      </swiper>
    </view>

    <!-- 养护信息区 -->
    <view class="care-info-section" wx:if="{{plantInfo && plantInfo.waterInterval}}">
      <view class="care-item">
        <view class="care-label-row">
          <text class="care-icon iconfont icon-Water"></text>
          <text class="care-label">浇水周期</text>
        </view>
        <text class="care-value">{{plantInfo.waterInterval}}天/次</text>
      </view>
      <view class="care-item">
        <view class="care-label-row">
          <text class="care-icon iconfont icon-riqi"></text>
          <text class="care-label">下次浇水</text>
        </view>
        <text class="care-value {{nextWatering.isOverdue ? 'warn' : ''}}">{{nextWatering.text}}</text>
      </view>
    </view>

    <view class="timeline-header">
      <text class="timeline-title">养成日记</text>
    </view>

    <view class="timeline-list" wx:if="{{journalList.length > 0}}">
      <view class="timeline-item" wx:for="{{journalList}}" wx:key="_id">
        <view class="timeline-axis">
          <view class="timeline-line"></view>
          <view class="timeline-dot {{item.photoFileID || (item.photoList && item.photoList.length > 0) ? 'bg-blue' : 'bg-green'}}">
            <text wx:if="{{item.photoFileID || (item.photoList && item.photoList.length > 0)}}" class="icon icon-image"></text>
            <text wx:else class="icon icon-jilu"></text>
          </view>
        </view>
        <view class="timeline-content">
          <view class="timeline-card" bindlongpress="{{isOwner ? 'deleteJournal' : ''}}" data-id="{{item._id}}" data-index="{{index}}">
            <view class="card-header">
              <!-- 渲染动作标签列表 -->
              <view class="action-tag-list" wx:if="{{item.renderActions && item.renderActions.length > 0}}">
                <view class="action-tag" wx:for="{{item.renderActions}}" wx:for-item="action" wx:key="label">
                  <text class="iconfont {{action.icon}} action-tag-icon"></text>
                  <text class="action-label">{{action.label}}</text>
                </view>
              </view>
              <text class="action-title" wx:else>记录成长</text>
              <text class="action-date">{{item.formatTime}}</text>
            </view>
            <text class="action-note" wx:if="{{item.note}}">{{item.note}}</text>
            
            <view class="photo-preview" wx:if="{{item.photoList && item.photoList.length > 0}}">
              <view class="journal-img-wrapper" wx:for="{{item.photoList}}" wx:for-item="img" wx:key="*this" bindtap="previewJournalImg" data-current="{{img}}" data-list="{{item.photoList}}">
                <image class="journal-img" src="{{img}}" mode="aspectFill"></image>
              </view>
            </view>
            <view class="photo-preview" wx:elif="{{item.photoFileID}}">
              <view class="journal-img-wrapper" bindtap="previewJournalImg" data-current="{{item.photoFileID}}" data-list="{{[item.photoFileID]}}">
                <image class="journal-img" src="{{item.photoFileID}}" mode="aspectFill"></image>
              </view>
            </view>

          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text>还没有记录哦，快去添加吧~</text>
    </view>

  </view>

  <view class="bottom-action-bar" wx:if="{{isOwner}}">
    <button class="btn-record" bindtap="openJournalPage">
      <text class="btn-icon icon icon-jilu"></text>
      <text class="btn-text">记录植物成长</text>
    </button>
    <button class="btn-share" open-type="share">
      <text class="btn-icon icon icon-share"></text>
      <text class="btn-text">分享植物获赞</text>
    </button>
  </view>

  </block>

</view>