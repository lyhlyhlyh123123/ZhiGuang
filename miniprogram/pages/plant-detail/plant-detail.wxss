/* miniprogram/pages/plant-detail/plant-detail.wxss */
page {
  background-color: #f8faf8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page-container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 200rpx; /* 给底部栏留出空间 */
}

/* 1. 顶部大图区 */
.hero-section {
  width: 100%;
  padding-top: 75%; /* 4:3 比例 */
  position: relative;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}

/* 2. 主体内容卡片 (负边距上浮) */
.content-card {
  flex: 1;
  background-color: #FFFFFF;
  margin-top: 0;
  border-radius: 0;
  position: relative;
  z-index: 10;
  padding: 32rpx 48rpx 64rpx;
}

/* 2. 头部操作区 */
.action-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 32rpx;
}

.edit-btn-mini {
  background: #F0FDF4;
  color: #16A34A;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 100rpx;
  border: 2rpx solid #DCFCE7;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.edit-btn-mini:active {
  background: #DCFCE7;
  transform: scale(0.95);
}

/* 植物信息展示区 - 新布局 */
.plant-info-section {
  padding: 24rpx 0 32rpx 0;
}

.plant-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.name-with-icon {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  flex: 1;
}

.plant-icon {
  font-size: 56rpx;
  color: #22C55E;
  flex-shrink: 0;
}

.plant-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #1F2937;
  line-height: 1.2;
}

.species-icon {
  font-size: 36rpx;
  color: #10B981;
  flex-shrink: 0;
}

.plant-latin {
  font-size: 30rpx;
  color: #9CA3AF;
  font-style: italic;
  line-height: 1.3;
}

.edit-btn {
  background-color: #F3F4F6;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.edit-btn.btn-primary {
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}

.edit-btn.btn-danger {
  background: linear-gradient(135deg, #FCA5A5 0%, #EF4444 100%);
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.edit-btn.btn-danger .edit-text {
  color: #FFFFFF;
  font-size: 32rpx;
}

.name-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  align-items: center;
}

/* 迷你点赞按钮 */
.like-button-mini {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 100rpx;
  padding: 12rpx 20rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.like-button-mini:active {
  transform: scale(0.95);
}

.like-button-mini.liked {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  border-color: #FCA5A5;
  box-shadow: 0 4rpx 10rpx rgba(239, 68, 68, 0.2);
}

.like-icon-mini {
  font-size: 32rpx;
  color: #D1D5DB;
  transition: all 0.3s ease;
}

.like-button-mini.liked .like-icon-mini {
  color: #EF4444;
  animation: thumbUp 0.5s ease;
}

@keyframes thumbUp {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.2) rotate(-10deg); }
  50% { transform: scale(1.1) rotate(5deg); }
  75% { transform: scale(1.15) rotate(-5deg); }
}

.like-count-mini {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 600;
  min-width: 20rpx;
  text-align: center;
}

.like-button-mini.liked .like-count-mini {
  color: #DC2626;
}

.edit-text {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 500;
}

.edit-btn.btn-primary .edit-text {
  color: #FFFFFF;
  font-weight: 600;
}

/* 信息卡片轮播 */
.info-swiper {
  width: 100%;
  height: 280rpx;
  margin-bottom: 24rpx;
}

.swiper-card {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

/* 第1页：三列布局（位置、陪伴、亲密度） */
.card-three-col {
  width: 100%;
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.col-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.col-icon {
  font-size: 48rpx;
}

.col-item:nth-child(1) .col-icon {
  color: #3B82F6; /* 蓝色-位置 */
}

.col-item:nth-child(2) .col-icon {
  color: #F59E0B; /* 橙色-陪伴 */
}

.col-item:nth-child(3) .col-icon {
  color: #EF4444; /* 红色-亲密度 */
}

.col-label {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.col-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1;
}

.col-value.highlight {
  color: #EF4444;
}

.col-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #6B7280;
}

/* 第2页和第3页：单个信息卡片（来源/备注） */
.card-single {
  width: 100%;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.single-icon {
  font-size: 48rpx;
  color: #22C55E;
}

.single-label {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.single-value {
  font-size: 32rpx;
  color: #1F2937;
  line-height: 1.6;
  word-break: break-all;
  text-align: center;
  max-width: 85%;
  font-weight: 600;
}

/* 备注信息区（单独一行） */
.remark-section {
  background: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #F3F4F6;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.remark-icon {
  font-size: 32rpx;
  color: #10B981;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.remark-label {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
  flex-shrink: 0;
}

.remark-content {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
  flex: 1;
  word-break: break-all;
}


/* 养护信息区 */
.care-info-section {
  background-color: #F9FAFB;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.care-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.care-item:first-child {
  border-bottom: 1rpx solid #E5E7EB;
}

.care-label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.care-icon {
  font-size: 36rpx;
}

.care-label {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
}

.care-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #1F2937;
}

.care-value.warn {
  color: #F59E0B;
}

/* 4. 时间轴 */
.timeline-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F3F4F6;
}

.timeline-title { 
  font-size: 32rpx; 
  font-weight: bold; 
  color: #1F2937; 
}

.timeline-item { display: flex; margin-bottom: 32rpx; }
.timeline-axis {
  position: relative;
  width: 60rpx;
  display: flex;
  justify-content: center;
}
.timeline-line {
  position: absolute;
  top: 32rpx;
  bottom: -32rpx;
  width: 4rpx;
  background-color: #F3F4F6;
  z-index: 0;
}
.timeline-item:last-child .timeline-line { display: none; }

.timeline-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 8rpx solid #FFFFFF;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 10;
  background-color: transparent;
}
.timeline-dot.bg-green { background-color: transparent; }
.timeline-dot.bg-blue { background-color: transparent; }

/* 时间轴图标颜色 - 绿色图标 */
.timeline-dot-icon { color: #22C55E; font-size: 32rpx; }

.timeline-content { flex: 1; padding-left: 16rpx; }
.timeline-card {
  background-color: #F9FAFB;
  border-radius: 32rpx;
  padding: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.action-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

.action-tag {
  display: flex;
  align-items: center;
  background-color: #F0FDF4;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #DCFCE7;
}

.action-tag .icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

/* 卡片操作图标颜色 */
.action-tag .icon-image { color: #8B5CF6; }
.action-tag .icon-jilu { color: #10B981; }

/* 时间轴动作标签图标 */
.action-tag-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}
.action-tag .icon-Water { color: #3B82F6; }
.action-tag .icon-sun { color: #F97316; }
.action-tag .icon-feiliao { color: #F59E0B; }
.action-tag .icon-Scissors { color: #10B981; }
.action-tag .icon-penzai { color: #22C55E; }
.action-tag .icon-qingkong { color: #EF4444; }

.action-label {
  font-size: 26rpx;
  color: #166534;
  font-weight: 500;
}

.action-title { font-size: 28rpx; font-weight: bold; color: #374151; }
.action-date { font-size: 24rpx; color: #9CA3AF; margin-left: 16rpx; white-space: nowrap; }
.action-note { font-size: 28rpx; color: #6B7280; display: block; margin-top: 8rpx;}

.photo-preview {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
}

.journal-img-wrapper {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F0FDF4;
}

.journal-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}

/* 5. 底部固定栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24rpx 32rpx 48rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  gap: 16rpx;
  box-sizing: border-box;
  z-index: 100;
}

.btn-share,
.btn-record {
  flex: 1;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx; /* ✨ 增加图标与文字的间距 */
  display: inline-block;
  line-height: 1;
}

.btn-text {
  display: inline-block;
}

.btn-share {
  background-color: #DBEAFE;
  color: #1E40AF;
}

.btn-share .icon-share { color: #3B82F6; }

.btn-record {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #FFFFFF;
}

.btn-record .icon-jilu { color: #FFFFFF; }

.btn-share::after,
.btn-record::after {
  border: none;
}

/* 骨架屏 */
@keyframes shimmer {
  0% { background-position: -750rpx 0; }
  100% { background-position: 750rpx 0; }
}

.skeleton-wrap {
  min-height: 100vh;
  background: #f8faf8;
}

.skeleton-hero {
  width: 100%;
  padding-top: 75%; /* 与 hero-section 保持一致 */
  background: linear-gradient(90deg, #e8f5e9 25%, #d0ead2 50%, #e8f5e9 75%);
  background-size: 750rpx 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-card {
  background: #FFFFFF;
  margin-top: 0;
  border-radius: 0;
  padding: 64rpx 48rpx;
  min-height: 60vh;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 14rpx;
  background: linear-gradient(90deg, #e8f5e9 25%, #d0ead2 50%, #e8f5e9 75%);
  background-size: 750rpx 100%;
  animation: shimmer 1.4s infinite;
  margin-bottom: 24rpx;
  width: 100%;
}

.skeleton-title {
  height: 48rpx;
  width: 50%;
  margin-bottom: 40rpx;
}

.skeleton-short {
  width: 40%;
}

.skeleton-tags {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.skeleton-tag {
  flex: 1;
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #e8f5e9 25%, #d0ead2 50%, #e8f5e9 75%);
  background-size: 750rpx 100%;
  animation: shimmer 1.4s infinite;
}
