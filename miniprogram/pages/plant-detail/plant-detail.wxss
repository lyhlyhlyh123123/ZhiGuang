/* miniprogram/pages/plant-detail/plant-detail.wxss */
page {
  background-color: #f8faf8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.page-container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 200rpx; /* 给底部栏留出空间 */
}

/* 1. 顶部轮播图区 */
.hero-section {
  width: 100%;
  background-color: #F5F5F5; /* 浅灰背景,参考小红书 */
  position: relative;
}

/* 轮播图容器 - 动态高度,参考小红书全宽自适应逻辑 */
.plant-swiper {
  width: 100%;
  min-height: 400rpx; /* 最小高度40vh */
  max-height: 1200rpx; /* 最大高度80vh */
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 轮播项包裹容器 */
.swiper-image-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
}

/* 自定义切换点容器 */
.custom-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 15rpx 0;
  background-color: #FFFFFF;
  gap: 10rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.dot.active {
  width: 24rpx;
  border-radius: 6rpx;
  background: #22C55E;
}

/* 图片样式 - widthFix模式自动计算高度 */
.hero-bg {
  width: 100%; /* 宽度撑满 */
  max-width: 100%;
  height: auto; /* 高度自动,保持比例 */
  display: block;
  object-fit: contain; /* 完整显示,留白不拉伸,参考小红书 */
  background-color: transparent;
}

/* 图片计数器（右上角） */
.photo-counter {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  color: white;
  font-size: 24rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  z-index: 5;
}

/* 2. 主体内容卡片 (负边距上浮) */
.content-card {
  flex: 1;
  background-color: #FFFFFF;
  margin-top: 0;
  border-radius: 0;
  position: relative;
  z-index: 10;
  padding: 0rpx 48rpx 64rpx;
}

/* 2. 头部操作区 */
.action-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 32rpx;
}

.edit-btn-mini {
  background: #F0FDF4;
  color: #16A34A;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 100rpx;
  border: 2rpx solid #DCFCE7;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.edit-btn-mini:active {
  background: #DCFCE7;
  transform: scale(0.95);
}

/* 植物信息展示区 - 新布局 */
.plant-info-section {
  padding: 8rpx 0 16rpx 0;
}

/* 名字和操作按钮行 */
.plant-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

/* 分隔线 */
.divider-line {
  height: 2rpx;
  background: #E5E7EB;
  margin: 16rpx 0;
}

.plant-name {
  font-size: 43rpx;
  font-weight: bold;
  color: #1F2937;
  line-height: 1.2;
  flex: 1;
}

.name-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  align-items: center;
}

/* 操作按钮统一样式 */
.action-icon-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.action-icon-btn:active {
  transform: scale(0.95);
}

.action-icon-btn .iconfont {
  font-size: 40rpx;
}

/* 点赞按钮包裹容器 */
.like-btn-wrapper {
  position: relative;
  flex-shrink: 0;
}

/* 点赞按钮 */
.like-btn {
  background: #FFE5EC;
}

.like-btn .iconfont {
  color: #FF6B9D;
}

.like-btn.liked {
  background: #FFD6E0;
}

.like-btn.liked .iconfont {
  color: #FF1A75;
  animation: thumbUp 0.5s ease;
}

/* 点赞数徽章（右上角） */
.like-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #FF1A75;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 8rpx;
  border-radius: 100rpx;
  min-width: 32rpx;
  text-align: center;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(255, 26, 117, 0.3);
}

@keyframes thumbUp {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.2) rotate(-10deg); }
  50% { transform: scale(1.1) rotate(5deg); }
  75% { transform: scale(1.15) rotate(-5deg); }
}

/* 编辑按钮 */
.edit-btn {
  background: #E8F5E9;
}

.edit-btn .iconfont {
  color: #4CAF50;
}

/* 删除按钮 */
.delete-btn {
  background: #FFEBEE;
}

.delete-btn .iconfont {
  color: #F44336;
}

/* 种类行 */
.plant-species-row {
  margin-bottom: 12rpx;
}

.plant-species {
  font-size: 28rpx;
  color: #9CA3AF;
  font-style: italic;
  line-height: 1.4;
}


/* 信息卡片轮播包裹容器 */
.info-swiper-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

/* 信息卡片轮播 */
.info-swiper {
  width: 100%;
  height: 100rpx;
}

/* 轮播箭头 */
.swiper-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 72rpx;
  color: #D1D5DB;
  z-index: 10;
  font-weight: 300;
  line-height: 1;
}

.swiper-card {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

/* 第1页：三列布局（位置、陪伴、亲密度） */
.card-three-col {
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 20rpx 16rpx;
}

.col-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

/* 图标+标签组合（横向排列） */
.col-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.col-icon {
  font-size: 40rpx;
}

.col-item:nth-child(1) .col-icon {
  color: #3B82F6; /* 蓝色-位置 */
}

.col-item:nth-child(2) .col-icon {
  color: #F59E0B; /* 橙色-陪伴 */
}

.col-item:nth-child(3) .col-icon {
  color: #EF4444; /* 红色-亲密度 */
}

.col-label {
  font-size: 30rpx;
  color: #9CA3AF;
  font-weight: normal;
}

/* 数值显示 */
.col-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #1F2937;
  line-height: 1;
}

.col-value.highlight {
  color: #EF4444;
}

.col-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #6B7280;
}

/* 第2页和第3页：单个信息卡片（来源/备注） */
.card-single {
  width: 100%;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.single-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.single-icon {
  font-size: 40rpx;
  color: #22C55E;
}

.single-label {
  font-size: 30rpx;
  color: #9CA3AF;
  font-weight: normal;
}

.single-value {
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.4;
  text-align: center;
  max-width: 85%;
  font-weight: bold;
  /* 限制单行显示，超出显示省略号 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}


/* 备注信息区（单独一行） */
.remark-section {
  background: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #F3F4F6;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.remark-icon {
  font-size: 32rpx;
  color: #10B981;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.remark-label {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
  flex-shrink: 0;
}

.remark-content {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
  flex: 1;
  word-break: break-all;
}


/* 养护信息分隔区 */
.care-divider {
  height: 16rpx;
  background: #F3F4F6;
  margin: 0 -48rpx 24rpx -48rpx;
}

/* 养护标题 */
.care-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 24rpx;
}

/* 养护信息区 */
.care-info-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

/* 养护卡片项 */
.care-card-item {
  flex: 1;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1rpx solid #E5E7EB;
}

.care-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.care-card-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.care-card-item:first-child .care-card-icon {
  color: #3B82F6;
}

.care-card-item:last-child .care-card-icon {
  color: #F59E0B;
}

.care-card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.care-card-label {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
  text-align: center;
}

.care-card-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #1F2937;
  text-align: center;
}

.care-card-value.warn {
  color: #F59E0B;
}

/* 4. 时间轴 */
.timeline-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F3F4F6;
}

.timeline-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
}

.timeline-item { display: flex; margin-bottom: 32rpx; }
.timeline-axis {
  position: relative;
  width: 60rpx;
  display: flex;
  justify-content: center;
}
.timeline-line {
  position: absolute;
  top: 32rpx;
  bottom: -32rpx;
  width: 4rpx;
  background-color: #F3F4F6;
  z-index: 0;
}
.timeline-item:last-child .timeline-line { display: none; }

.timeline-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 8rpx solid #FFFFFF;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 10;
  background-color: transparent;
}
.timeline-dot.bg-green { background-color: transparent; }
.timeline-dot.bg-blue { background-color: transparent; }

/* 时间轴图标颜色 - 绿色图标 */
.timeline-dot-icon { color: #22C55E; font-size: 32rpx; }

.timeline-content { flex: 1; padding-left: 16rpx; }
.timeline-card {
  background-color: #F9FAFB;
  border-radius: 32rpx;
  padding: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.action-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

.action-tag {
  display: flex;
  align-items: center;
  background-color: #F0FDF4;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #DCFCE7;
}

.action-tag .icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

/* 卡片操作图标颜色 */
.action-tag .icon-image { color: #8B5CF6; }
.action-tag .icon-jilu { color: #10B981; }

/* 时间轴动作标签图标 */
.action-tag-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}
.action-tag .icon-Water { color: #3B82F6; }
.action-tag .icon-sun { color: #F97316; }
.action-tag .icon-feiliao { color: #F59E0B; }
.action-tag .icon-Scissors { color: #10B981; }
.action-tag .icon-penzai { color: #22C55E; }
.action-tag .icon-qingkong { color: #EF4444; }

.action-label {
  font-size: 26rpx;
  color: #166534;
  font-weight: 500;
}

.action-title { font-size: 28rpx; font-weight: bold; color: #374151; }
.action-date { font-size: 24rpx; color: #9CA3AF; margin-left: 16rpx; white-space: nowrap; }
.action-note { font-size: 28rpx; color: #6B7280; display: block; margin-top: 8rpx;}

.photo-preview {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
}

.journal-img-wrapper {
  position: relative;
  width: 100%;
  padding-top: 100%; /* 正方形比例 */
  border-radius: 12rpx;
  overflow: hidden;
  background: #F0FDF4;
}

.journal-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* 图片覆盖容器,居中裁剪 */
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}

/* 5. 底部固定栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24rpx 32rpx 48rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  gap: 16rpx;
  box-sizing: border-box;
  z-index: 100;
}

.btn-share,
.btn-record {
  flex: 1;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx; /* ✨ 增加图标与文字的间距 */
  display: inline-block;
  line-height: 1;
}

.btn-text {
  display: inline-block;
}

.btn-share {
  background-color: #DBEAFE;
  color: #1E40AF;
}

.btn-share .icon-share { color: #3B82F6; }

.btn-record {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #FFFFFF;
}

.btn-record .icon-jilu { color: #FFFFFF; }

.btn-share::after,
.btn-record::after {
  border: none;
}

/* 骨架屏 */
@keyframes shimmer {
  0% { background-position: -750rpx 0; }
  100% { background-position: 750rpx 0; }
}

.skeleton-wrap {
  min-height: 100vh;
  background: #f8faf8;
}

.skeleton-hero {
  width: 100%;
  padding-top: 75%; /* 与 hero-section 保持一致 */
  background: linear-gradient(90deg, #e8f5e9 25%, #d0ead2 50%, #e8f5e9 75%);
  background-size: 750rpx 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-card {
  background: #FFFFFF;
  margin-top: 0;
  border-radius: 0;
  padding: 64rpx 48rpx;
  min-height: 60vh;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 14rpx;
  background: linear-gradient(90deg, #e8f5e9 25%, #d0ead2 50%, #e8f5e9 75%);
  background-size: 750rpx 100%;
  animation: shimmer 1.4s infinite;
  margin-bottom: 24rpx;
  width: 100%;
}

.skeleton-title {
  height: 48rpx;
  width: 50%;
  margin-bottom: 40rpx;
}

.skeleton-short {
  width: 40%;
}

.skeleton-tags {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.skeleton-tag {
  flex: 1;
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #e8f5e9 25%, #d0ead2 50%, #e8f5e9 75%);
  background-size: 750rpx 100%;
  animation: shimmer 1.4s infinite;
}
