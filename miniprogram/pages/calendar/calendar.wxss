page { background: #F0FDF4; font-family: -apple-system, sans-serif; }
.page { padding: 32rpx 32rpx 200rpx; }

.month-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.nav-arrow { width: 72rpx; height: 72rpx; background: #FFFFFF; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 48rpx; color: #16A34A; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.month-title { font-size: 36rpx; font-weight: 800; color: #1F2937; }

.week-header { display: grid; grid-template-columns: repeat(7, 1fr); margin-bottom: 12rpx; }
.week-label { text-align: center; font-size: 24rpx; color: #9CA3AF; padding: 8rpx 0; }

.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8rpx; background: #FFFFFF; border-radius: 32rpx; padding: 24rpx 16rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); margin-bottom: 32rpx; }
.day-cell { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 80rpx; border-radius: 16rpx; position: relative; }
.day-cell.empty { pointer-events: none; }
.day-cell.today { background: #DCFCE7; }
.day-cell.selected { background: #16A34A; }
.day-num { font-size: 28rpx; color: #374151; font-weight: 500; }
.day-cell.today .day-num { color: #16A34A; font-weight: 800; }
.day-cell.selected .day-num { color: #FFFFFF; font-weight: 700; }
.dot { width: 10rpx; height: 10rpx; background: #22C55E; border-radius: 50%; position: absolute; bottom: 6rpx; }
.day-cell.selected .dot { background: #FFFFFF; }

.detail-title { font-size: 30rpx; font-weight: 700; color: #1F2937; margin-bottom: 20rpx; display: block; }
.no-record { text-align: center; color: #9CA3AF; font-size: 28rpx; padding: 40rpx 0; }
.journal-item { background: #FFFFFF; border-radius: 24rpx; padding: 28rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.journal-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.journal-plant-info { display: flex; flex-direction: column; gap: 4rpx; }
.journal-plant { font-size: 30rpx; font-weight: 700; color: #166534; }
.journal-meta { font-size: 22rpx; color: #9CA3AF; }
.journal-time { font-size: 22rpx; color: #9CA3AF; flex-shrink: 0; margin-left: 16rpx; }
.journal-actions { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 12rpx; }
.action-tag { background: #F0FDF4; border-radius: 12rpx; padding: 6rpx 18rpx; border: 1rpx solid #DCFCE7; }
.action-tag-label { font-size: 24rpx; color: #166534; font-weight: 500; }
.journal-note { font-size: 26rpx; color: #374151; display: block; margin-bottom: 12rpx; }
.journal-photos { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 12rpx; }
.journal-photo { width: 140rpx; height: 140rpx; border-radius: 12rpx; }
